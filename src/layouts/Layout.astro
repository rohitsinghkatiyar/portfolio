---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "Rohit Singh Katiyar | Senior Frontend Engineer",
	description = "Senior Frontend Engineer who builds fast things — apps, systems, and occasionally takes corners at speed. React, TypeScript, AI workflows."
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="theme-color" content="#0d0d12" />

		<!-- Open Graph -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />

		<!-- Preconnect to Google Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link 
			href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;700&display=swap" 
			rel="stylesheet" 
		/>
	</head>
	<body>
		<!-- Cursor glow element -->
		<div class="cursor-glow" id="cursor-glow"></div>

		<slot />
		
		<!-- Theme script — prevent FOUC -->
		<script is:inline>
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return 'dark';
			})();

			if (theme === 'light') {
				document.documentElement.classList.remove('dark');
			} else {
				document.documentElement.classList.add('dark');
			}
			window.localStorage.setItem('theme', theme ?? 'dark');
		</script>

		<!-- Cursor glow tracker -->
		<script is:inline>
			const cursorGlow = document.getElementById('cursor-glow');
			if (cursorGlow) {
				document.addEventListener('mousemove', (e) => {
					cursorGlow.style.left = e.clientX + 'px';
					cursorGlow.style.top = e.clientY + 'px';
				});
			}
		</script>
	</body>
</html>
